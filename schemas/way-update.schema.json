{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ccc.local/schemas/way-update.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "run_id",
    "way_attempt_id",
    "source",
    "summary",
    "way_mode",
    "clarification_request",
    "task_card_count",
    "task_kind_counts",
    "task_cards",
    "recorded_at"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "way_attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": ["way", "replan"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "way_mode": {
      "type": "string",
      "enum": ["task_cards", "clarification_request"]
    },
    "clarification_request": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "task_card_count": {
      "type": "integer",
      "minimum": 0
    },
    "task_kind_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution", "review", "explore", "way"],
      "properties": {
        "execution": { "type": "integer", "minimum": 0 },
        "review": { "type": "integer", "minimum": 0 },
        "explore": { "type": "integer", "minimum": 0 },
        "way": { "type": "integer", "minimum": 0 }
      }
    },
    "task_cards": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "title",
          "task_kind",
          "node_kind",
          "auto_review_after",
          "depends_on_indexes",
          "fan_in_from_indexes"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "task_kind": {
            "type": "string",
            "enum": ["execution", "review", "explore", "way"]
          },
          "node_kind": {
            "type": "string",
            "enum": ["execution", "fan_in"]
          },
          "auto_review_after": {
            "type": "boolean"
          },
          "depends_on_indexes": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0
            },
            "uniqueItems": true
          },
          "fan_in_from_indexes": {
            "type": "array",
            "items": {
              "type": "integer",
              "minimum": 0
            },
            "uniqueItems": true
          }
        }
      }
    },
    "recorded_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
