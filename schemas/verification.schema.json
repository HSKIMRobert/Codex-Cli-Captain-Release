{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ccc.local/schemas/verification.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["outcome", "summary"],
  "properties": {
    "outcome": {
      "type": "string",
      "enum": ["passed", "needs_work", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
