{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ccc.local/schemas/advisor.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "recommended_next_action"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "recommended_next_action": {
      "type": "string",
      "enum": [
        "advance",
        "verify",
        "resolve",
        "retry",
        "replan"
      ]
    }
  }
}
