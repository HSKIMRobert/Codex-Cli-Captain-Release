                      "type": "boolean"
                    },
                    "needs_investigation": {
                      "type": "boolean"
                    },
                    "needs_mutation": {
                      "type": "boolean"
                    },
                    "needs_review": {
                      "type": "boolean"
                    },
                    "needs_ownership_check": {
                      "type": "boolean"
                    },
                    "output_kind": {
                      "type": "string",
                      "enum": ["answer", "docs", "code", "mixed"]
                    },
                    "mutation_mode": {
                      "type": "string",
                      "enum": ["none", "conditional", "required"]
                    },
                    "parallel": {
                      "type": "boolean"
                    },
                    "risk": {
                      "type": "string",
                      "enum": ["low", "medium", "high"]
                    }
                  }
