          "type": "string",
          "enum": ["new_run_created", "existing_run_reused", "no_run_created"]
        },
        "requester_session_id": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "continuity_strategy": {
          "type": "string",
          "enum": ["session_fresh_run_first", "session_bound_first", "workspace_run_search"]
