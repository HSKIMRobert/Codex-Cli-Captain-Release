            "companion_tool_names": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["filesystem", "git", "context7", "fetch", "openaiDeveloperDocs"]
              }
            },
            "companion_tool_operation": {
              "type": "string",
              "enum": ["none", "read", "mutation"]
