                "phases": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "phase",
                      "owner_agent",
                      "requires_codex_exec",
                      "skill_contract",
                      "preconditions",
                      "handoff_inputs"
