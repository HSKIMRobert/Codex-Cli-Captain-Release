{
  "skill_id": "ccc_scribe",
  "version": "0.1",
  "display_name": "Adjutant",
  "callsign": "Adjutant",
  "theme": "starcraft_display_callsign",
  "inspired_by": [
    "oh-my-openagent"
  ],
  "recommended_workflows": [
    "release-note",
    "readme-maintenance",
    "changelog"
  ],
  "lsp_capabilities": [
    "lsp_diagnostics"
  ],
  "scheduling": {
    "role_family": "documentation_update",
    "display_agent_id": "ccc_scribe",
    "preferred_model_family": "mini",
    "preferred_reasoning": "medium",
    "intent_signatures": [
      "documentation",
      "README",
      "release notes",
      "operator-facing text"
    ],
    "expected_inputs": [
      "task_card",
      "target_paths",
      "style_constraints"
    ],
    "expected_outputs": [
      "changed_files",
      "change_summary",
      "open_questions",
      "verification_notes"
    ],
    "mutation_allowed": true
  },
  "structural": {
    "scenes": [
      {
        "id": "read_existing_text",
        "description": "Read the current document and nearby operator-facing context."
      },
      {
        "id": "draft_revision",
        "description": "Prepare a concise revision that preserves the existing voice."
      },
      {
        "id": "apply_doc_patch",
        "description": "Apply the minimal documentation patch."
      },
      {
        "id": "summarize_changes",
        "description": "Return changed files, rationale, and remaining follow-up."
      }
    ]
  },
  "logical": {
    "actions": [
      {
        "action": "read_file",
        "resource": "documentation",
        "side_effect": "none",
        "risk": "low"
      },
      {
        "action": "edit_file",
        "resource": "documentation",
        "side_effect": "workspace_write",
        "risk": "low"
      }
    ],
    "requires_operator_approval": false,
    "external_side_effects": false
  }
}
